# Hugging Face Hub upload excludes for `openenv push`.
#
# IMPORTANT — OpenEnv behavior (see Meta OpenEnv `push.py`):
#   - Pass this file explicitly: `openenv push . --repo-id ... --exclude .hfignore`
#     (`openenv push` does NOT auto-load this file.)
#   - Lines starting with `!` (gitignore-style negation) are IGNORED by OpenEnv push.
#     Do not use negation here; list only positive exclude globs.
#
# Keep in sync with deployment intent in `.dockerignore` where patterns overlap.

.git
.github

__pycache__
**/__pycache__
*.py[cod]
*$py.class
.pytest_cache
.mypy_cache
.ruff_cache
.venv
venv
.env
.env.*
*.egg-info
.eggs
dist
build

# Tests & local gate harness (not Space runtime)
tests
test_*.py
test_local_deployment.sh
test_api_complete.sh
test_hf_space_deployment.py
test_regression_local.py
gate.sh

# Colab / package training code (Space serves API + Streamlit; keep root train.py / inference.py for OpenEnv layout)
training
training_simulator.py
scripts

deploy_to_hf_spaces.py
docker-compose.yml

# Large / local-only artifacts (Hub file browser stays lean; canonical notebooks stay — not listed here)
NEXUS_GRPO_backups
grpo_checkpoints
wandb

# Legacy / duplicate entrypoints (start.sh uses streamlit_app_v2.py only)
gradio_app.py
gradio_app_backup.py
gradio_app_minimal.py
streamlit_app.py
router.py

# External archive root (outside repo)
../archive/
../archive/**
